{
	"version": "2",
	"label": "Shopify product fields",
	"description": "Extends shop/product with Shopify sync fields; marks synced catalogue fields readonly",
	"extra_buttons": [
		{
			"name": "shopify/shopify_productrefresh",
			"position": "none"
		}
	],
	"item": [
		{
			"name": "heading",
			"readonly": "1"
		},
		{
			"name": "image",
			"readonly": "1",
			"category": "shopify"
		},
		{
			"name": "type",
			"readonly": "1"
		},
		{
			"name": "text",
			"readonly": "1"
		},
		{
			"name": "min_price",
			"readonly": "1"
		},
		{
			"name": "max_price",
			"readonly": "1"
		},
		{
			"name": "available",
			"readonly": "1"
		},
		{
			"name": "images",
			"readonly": "1",
			"fields": [
				{
					"name": "image",
					"readonly": "1",
					"category": "shopify"
				},
				{
					"name": "image_update",
					"readonly": "1"
				},
				{
					"name": "shopify_id",
					"label": "Shopify image ID",
					"readonly": "1"
				}
			]
		},
		{
			"type": "subtitle",
			"label": "Shopify"
		},
		{
			"type": "text",
			"name": "shopify_id",
			"label": "Shopify ID",
			"readonly": "1"
		},
		{
			"type": "select",
			"name": "shopify_status",
			"label": "Shopify status",
			"values": {
				"unconfirmed": "Unconfirmed",
				"active": "Active",
				"unavailable": "Unavailable"
			},
			"default": "unconfirmed",
			"readonly": "1"
		},
		{
			"type": "text",
			"name": "last_update",
			"label": "Last update",
			"readonly": "1"
		},
		{
			"type": "text",
			"name": "shopify_updated_at",
			"label": "Shopify updated",
			"readonly": "1",
			"help": "Unix time of product.updated_at from Shopify; used by Sync to skip unchanged products"
		},
		{
			"type": "text",
			"name": "shopify_checked_at",
			"label": "Shopify checked",
			"readonly": "1",
			"help": "Unix time of last successful Shopify Admin product fetch for this CMS product"
		},
		{
			"type": "text",
			"name": "image_update",
			"label": "Image last update",
			"readonly": "1"
		},
		{
			"type": "text",
			"name": "image_name_hash",
			"label": "Image name hash",
			"readonly": "1"
		}
	]
}
